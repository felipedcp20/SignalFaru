# Binance API Configuration
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
TESTNET=false

# Modo Demo — true para datos simulados sin operaciones reales (para compartir/demostrar)
DEMO_MODE=false

# CoinScanX API Configuration
COINSCANX_API_KEY=your_coinscanx_api_key_here

# CoinGecko Demo API Configuration (free; used for social links metadata)
COINGECKO_API_KEY=your_coingecko_demo_api_key_here

# JWT Secret — obligatorio: generá una cadena aleatoria de al menos 32 caracteres
# Ejemplo: openssl rand -hex 32
# Si no se configura, la app genera uno efímero y las sesiones se pierden al reiniciar.
JWT_SECRET=

# Database Configuration (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///./signalfaru.db
